# Copy to .env and fill in real values.
# Never commit .env.

# PostgreSQL (Neon recommended)
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"

# OpenAI — inquiry classification & drafts
OPENAI_API_KEY="sk-..."
# Optional: override the default Responses API model.
# OPENAI_MODEL="gpt-5.2"

# App URL (no trailing slash) — used for OAuth redirects & public links
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Neon Auth (Better Auth) — from Neon project Auth settings
AUTH_URL="https://your-neon-auth-host.example.com"
# JWKS for optional bearer verification — Neon dashboard provides this URL
JWKS_URL="https://your-neon-auth-host.example.com/.well-known/jwks.json"

# Session cookie signing — REQUIRED in production (min 32 chars)
# openssl rand -base64 32
NEON_AUTH_COOKIE_SECRET="replace-with-openssl-rand-base64-32-chars-min"

# Optional: comma-separated Google Workspace domains, e.g. "acme.com,acme.io"
# AUTH_ALLOWED_EMAIL_DOMAINS=""

# Cron / worker auth — Vercel cron sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET="replace-with-long-random-string"

# Gmail OAuth (optional) — Google Cloud OAuth 2.0 client
# Authorized redirect URI must match exactly: {NEXT_PUBLIC_APP_URL}/api/gmail/callback
GMAIL_CLIENT_ID=""
GMAIL_CLIENT_SECRET=""
GMAIL_REDIRECT_URI="http://localhost:3000/api/gmail/callback"

# Encrypt Gmail refresh/access tokens at rest (base64 32-byte key)
# openssl rand -base64 32
MAIL_TOKEN_ENCRYPTION_KEY=""

# Channel webhooks (optional)
TELEGRAM_WEBHOOK_SECRET=""
WHATSAPP_VERIFY_TOKEN=""
META_APP_SECRET=""

# Skip Prisma migrate reminder in dev logs (optional)
# MEDA_SKIP_MIGRATION_WARNING=1
